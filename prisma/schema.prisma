// Prisma schema for CRM/ERP - 客户与外贸业务管理
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ Enums ============
enum CustomerStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum ExecutionStatus {
  DRAFT
  SENT
  CONFIRMED
  PENDING_PAYMENT
  PAID
  IN_PRODUCTION
  READY_TO_SHIP
  SHIPPED
  DOCUMENT_COMPLETED
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  COMPLETED
  CANCELLED
}

enum SignStatus {
  UNSIGNED
  SIGNED
  VOIDED
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum PiStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
}

enum ShipmentStatus {
  PENDING
  SHIPPED
  DELIVERED
  CANCELLED
}

// ============ Customer ============
model Customer {
  id                        String    @id @default(cuid())
  customerCode              String    @unique
  nameCn                    String?
  nameEn                    String?
  shortName                 String?
  country                   String?
  city                      String?
  address                   String?
  phone                     String?
  email                     String?
  website                   String?
  taxNo                     String?
  contactPerson             String?
  contactTitle              String?
  defaultCurrency           String?   @default("USD")
  defaultPaymentTerm        String?
  defaultIncoterm           String?
  defaultPortOfLoading     String?
  defaultPortOfDestination  String?
  defaultInsuranceTerm      String?
  defaultPackingTerm        String?
  defaultDocumentRequirement String?
  customerLevel             String?
  status                    CustomerStatus @default(ACTIVE)
  remark                    String?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  quotations                Quotation[]
  proformaInvoices          ProformaInvoice[]
  contracts                 Contract[]
  payments                  Payment[]
  shipments                 Shipment[]
}

// ============ Product ============
model Product {
  id                String   @id @default(cuid())
  productCode       String   @unique
  name              String
  category          String?
  material          String?
  thickness         String?
  width             String?
  length            String?
  density           Float?
  unit              String?  @default("kg")
  defaultPrice      Float?
  currency          String?  @default("USD")
  weightFormulaType String?
  pricingMethod     String?
  packingMethod     String?
  remark            String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  quotationItems    QuotationItem[]
  contractItems     ContractItem[]
  piItems           PiItem[]
}

// ============ Quotation ============
model Quotation {
  id           String          @id @default(cuid())
  quotationNo  String          @unique
  customerId   String
  quotationDate DateTime
  validUntil   DateTime?
  currency     String          @default("USD")
  paymentTerm  String?
  incoterm     String?
  remark       String?
  status       QuotationStatus @default(DRAFT)
  totalAmount  Float           @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  customer     Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items        QuotationItem[]

  proformaInvoices ProformaInvoice[]
  contracts        Contract[]
}

model QuotationItem {
  id          String   @id @default(cuid())
  quotationId String
  productId   String?
  productName String
  category    String?
  thickness   String?
  width       String?
  length      String?
  unitPrice   Float
  rollQty     Float    @default(0)
  quantityKg  Float    @default(0)
  amount      Float
  remark      String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product     Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
}

// ============ Proforma Invoice ============
model ProformaInvoice {
  id          String   @id @default(cuid())
  piNo        String   @unique
  customerId  String
  quotationId String?
  contractId  String?
  issueDate   DateTime
  currency    String   @default("USD")
  paymentTerm String?
  bankInfo    String?
  status      PiStatus @default(DRAFT)
  totalAmount Float    @default(0)
  remark      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  quotation    Quotation? @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  contract     Contract?  @relation(fields: [contractId], references: [id], onDelete: SetNull)
  piItems      PiItem[]
  payments     Payment[]
}

model PiItem {
  id          String   @id @default(cuid())
  piId        String
  productId   String?
  productName String
  category    String?
  thickness   String?
  width       String?
  length      String?
  unitPrice   Float
  rollQty     Float    @default(0)
  quantityKg  Float    @default(0)
  amount      Float
  remark      String?
  sortOrder   Int      @default(0)

  pi          ProformaInvoice @relation(fields: [piId], references: [id], onDelete: Cascade)
  product     Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
}

// ============ Contract ============
model Contract {
  id                  String           @id @default(cuid())
  contractNo          String           @unique
  contractDate        DateTime
  customerId          String
  quotationId         String?
  piId                String?
  currency            String           @default("USD")
  incoterm            String?
  paymentTerm         String?
  shipmentTerm        String?
  packingTerm         String?
  insuranceTerm       String?
  documentRequirement String?
  bankInfo            String?
  totalAmount         Float            @default(0)
  totalWeight        Float            @default(0)
  totalRolls         Float            @default(0)
  signStatus         SignStatus       @default(UNSIGNED)
  executionStatus    ExecutionStatus  @default(DRAFT)
  remark             String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  customer    Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  quotation   Quotation? @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  pi          ProformaInvoice? @relation(fields: [piId], references: [id], onDelete: SetNull)
  items       ContractItem[]
  packingLists PackingList[]
  shipments   Shipment[]
  payments    Payment[]
  logs        ContractLog[]
}

model ContractItem {
  id           String   @id @default(cuid())
  contractId   String
  productId    String?
  productName  String
  category     String?
  thickness    String?
  width        String?
  length       String?
  unitPrice    Float
  rollQty      Float    @default(0)
  quantityKg   Float    @default(0)
  actualQty    Float?   @default(0)
  confirmedQty Float?   @default(0)
  amount       Float
  remark       String?
  sortOrder    Int      @default(0)

  contract     Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model ContractLog {
  id         String   @id @default(cuid())
  contractId String
  actionType String
  content    String?
  operator   String?
  createdAt  DateTime @default(now())

  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
}

// ============ Packing List (CL) ============
model PackingList {
  id            String   @id @default(cuid())
  clNo          String   @unique
  contractId    String
  shipmentDate  DateTime?
  batchNo       String?
  packageCount  Int?
  netWeight     Float?
  grossWeight   Float?
  volume        Float?
  containerNo   String?
  sealNo        String?
  remark        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  contract      Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
}

// ============ Shipment ============
model Shipment {
  id                String         @id @default(cuid())
  shipmentNo        String         @unique
  contractId        String
  customerId        String
  etd               DateTime?
  eta               DateTime?
  shippingDate      DateTime?
  vesselVoyage      String?
  billOfLadingNo    String?
  portOfLoading     String?
  portOfDestination String?
  containerNo       String?
  sealNo            String?
  status            ShipmentStatus @default(PENDING)
  remark            String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  contract  Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  customer  Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

// ============ Payment ============
model Payment {
  id            String   @id @default(cuid())
  paymentNo     String   @unique
  customerId    String
  contractId    String?
  piId          String?
  paymentDate   DateTime
  amount        Float
  currency      String   @default("USD")
  exchangeRate  Float?   @default(1)
  paymentMethod String?
  bankReference String?
  remark        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer  Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  contract  Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  pi        ProformaInvoice? @relation(fields: [piId], references: [id], onDelete: SetNull)
}
